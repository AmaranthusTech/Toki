+def _terms_in_span_utc_left_closed(
+    s_utc: datetime,
+    e_utc: datetime,
+    zhongqi_events: List[Tuple[float, datetime]],
+    *,
+    epsilon_seconds: int = 0,
+) -> List[Tuple[int, datetime]]:
+    """
+    UTC strict判定で span への帰属を判定する。
+    判定基準: (start - eps) <= t < (end + eps)
+    """
+    eps = timedelta(seconds=int(epsilon_seconds)) if epsilon_seconds else timedelta(0)
+    lo = s_utc.astimezone(UTC) - eps
+    hi = e_utc.astimezone(UTC) + eps
+
+    out: List[Tuple[int, datetime]] = []
+    for deg, t in zhongqi_events:
+        if t.tzinfo is None:
+            t_utc = t.replace(tzinfo=UTC)
+        else:
+            t_utc = t.astimezone(UTC)
+        deg_i = int(round(float(deg))) % 360
+        if lo <= t_utc < hi:
+            out.append((deg_i, t_utc))
+    out.sort(key=lambda x: x[1])
+    return out
+
